APP_NAME=AgenticRAG
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agenticrag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
EMBEDDING_BACKEND=tei
TEI_BASE_URL=http://127.0.0.1:8080
TEI_API_KEY=
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
RETRIEVAL_CONTEXT_HISTORY_LIMIT=3
RERANKER_ENABLED=true
RERANKER_BACKEND=local
RERANKER_MODEL_NAME=/Users/zhujian/LocalLLMs/bge-reranker-v2-m3
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=MiniMax-M2.7
UPLOAD_DIR=var/uploads
PARSED_DIR=var/parsed
INDEX_DIR=var/indexes
LOG_DIR=var/logs
LOG_FILE=agenticrag.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
RQ_INGESTION_QUEUE=ingestion
RQ_INDEXING_QUEUE=indexing
RQ_INGESTION_TIMEOUT_SECONDS=900
RQ_INDEXING_TIMEOUT_SECONDS=900
RQ_MAX_RETRIES=2
RQ_WORKER_CLASS=simple
MAX_UPLOAD_SIZE_BYTES=52428800
PARSER_TIMEOUT_SECONDS=60
