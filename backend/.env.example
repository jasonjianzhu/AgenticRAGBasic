# Application
APP_NAME=AgenticRAG
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=false

# Database (async driver for FastAPI, sync driver for Alembic/RQ worker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agenticrag
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/agenticrag

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=agenticrag_chunks

# Embedding (BGE-M3)
# Provider: "local" (FlagEmbedding, dense+sparse) or "tei" (TEI HTTP, dense only if sparse unavailable)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MODEL_PATH=~/LocalLLMs/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_USE_FP16=true
# TEI fallback (used when EMBEDDING_PROVIDER=tei)
TEI_BASE_URL=http://127.0.0.1:8080
TEI_API_KEY=

# RQ Worker
RQ_INGESTION_QUEUE=ingestion
RQ_INDEXING_QUEUE=indexing
RQ_INGESTION_TIMEOUT=300
RQ_INDEXING_TIMEOUT=300
RQ_MAX_RETRIES=2

# File Storage
UPLOAD_DIR=var/uploads
PARSED_DIR=var/parsed
MAX_UPLOAD_SIZE_BYTES=52428800

# Logging
LOG_DIR=var/logs
LOG_LEVEL=INFO
LOG_FILE=agenticrag.log

# LLM (MiniMax M2.7, OpenAI-compatible API)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=minimax-m2.7
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# Reranker (TEI, default off)
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_ENABLED=false
RERANKER_TOP_N=20

# RAG
RAG_SEARCH_TOP_K=10
RAG_ANSWER_TOP_K=5
RAG_REWRITE_ENABLED=true
RAG_CONTEXT_WINDOW_TOKENS=4000
RAG_SCORE_THRESHOLD=0.01
RAG_REFUSAL_THRESHOLD=0.005

# Langfuse (optional)
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Parser
PARSER_TIMEOUT_SECONDS=300.0
