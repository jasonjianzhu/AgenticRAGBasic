# Application
APP_NAME=AgenticRAG
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=false

# Database (async driver for FastAPI, sync driver for Alembic/RQ worker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agenticrag
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/agenticrag

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=agenticrag_chunks

# Embedding (local loads BGE-M3 in-process)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=4
# 以下仅 EMBEDDING_PROVIDER=local 时生效
EMBEDDING_MODEL_PATH=~/LocalLLMs/bge-m3
EMBEDDING_USE_FP16=true
# TEI fallback (EMBEDDING_PROVIDER=tei 时生效)
TEI_BASE_URL=http://localhost:8080

# RQ Worker
RQ_INGESTION_QUEUE=ingestion
RQ_INDEXING_QUEUE=indexing
RQ_INGESTION_TIMEOUT=300
RQ_INDEXING_TIMEOUT=900
RQ_MAX_RETRIES=2

# File Storage
UPLOAD_DIR=var/uploads
PARSED_DIR=var/parsed
MAX_UPLOAD_SIZE_BYTES=52428800

# Logging
LOG_DIR=var/logs
LOG_LEVEL=INFO
LOG_FILE=agenticrag.log

# LLM (DeepSeek V4 Pro, Anthropic-compatible API)
LLM_BASE_URL=https://api.deepseek.com/anthropic
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=60

# Reranker (本地加载 BGE-Reranker)
RERANKER_ENABLED=true
RERANKER_PROVIDER=local
RERANKER_TOP_N=20
# 以下仅 RERANKER_PROVIDER=local 时生效
RERANKER_MODEL_PATH=~/LocalLLMs/bge-reranker-v2-m3

# RAG
RAG_SEARCH_TOP_K=20
RAG_ANSWER_TOP_K=10
RAG_REWRITE_ENABLED=false
RAG_CONTEXT_WINDOW_TOKENS=4000
RAG_SCORE_THRESHOLD=0.005
RAG_REFUSAL_THRESHOLD=0.005

# Langfuse
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Parser
PARSER_TIMEOUT_SECONDS=300.0

# Agent
AGENT_CONTEXT_WINDOW=20
AGENT_SESSION_TTL_HOURS=24

# Business Database (read-only, for Agent data analysis)
BUSINESS_DB_URL=postgresql+asyncpg://readonly:readonly@localhost:5433/energy_business
BUSINESS_DB_ALLOWED_TABLES=*
BUSINESS_DB_QUERY_TIMEOUT=30
BUSINESS_DB_MAX_ROWS=500
